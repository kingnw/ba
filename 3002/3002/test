import unittest
from app import app, db
from models import User

class AppTestCase(unittest.TestCase):
    @classmethod
    def setUpClass(cls):
        app.config['TESTING'] = True
        app.config['SQLALCHEMY_DATABASE_URI'] = 'sqlite:///test.db'
        cls.client = app.test_client()
        with app.app_context():
            db.create_all()

    @classmethod
    def tearDownClass(cls):
        with app.app_context():
            db.drop_all()

    def setUp(self):
        self.client = self.client
        with app.app_context():
            pass

    def tearDown(self):
        with app.app_context():
            db.session.remove()

    def test_index_page(self):
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        self.assertIn(b"Trending Movies", response.data)

    def test_user_registration(self):
        response = self.client.post('/auth/register', data={
            'username': 'testuser',
            'password': 'password123'
        }, follow_redirects=True)
        self.assertEqual(response.status_code, 200)
        self.assertIn(b"Registration successful. Please log in.", response.data)

    def test_user_login(self):
        with app.app_context():
            User.create_user(username='testuser', password='password123')
        response = self.client.post('/auth/login', data={
            'username': 'testuser',
            'password': 'password123'
        }, follow_redirects=True)
        self.assertEqual(response.status_code, 200)
        self.assertIn(b"Logged in successfully.", response.data)

    def test_user_logout(self):
        with self.client:
            with app.app_context():
                User.create_user(username='testuser', password='password123')
            self.client.post('/auth/login', data={
                'username': 'testuser',
                'password': 'password123'
            })
            response = self.client.get('/auth/logout', follow_redirects=True)
            self.assertEqual(response.status_code, 200)
            self.assertIn(b"You have been logged out.", response.data)

    def test_movie_details_page(self):
        movie_id = 1
        response = self.client.get(f'/movie/{movie_id}')
        self.assertEqual(response.status_code, 200)
        self.assertIn(b"Similar Movies That You May Like", response.data)

    def test_add_to_watchlist(self):
        with self.client:
            with app.app_context():
                User.create_user(username='testuser', password='password123')
            self.client.post('/auth/login', data={
                'username': 'testuser',
                'password': 'password123'
            })
            response = self.client.post('/watchlist/add/1', follow_redirects=True)
            self.assertEqual(response.status_code, 200)
            self.assertIn(b"Added to Watchlist", response.data)

    def test_add_to_favorites(self):
        with self.client:
            with app.app_context():
                User.create_user(username='testuser', password='password123')
            self.client.post('/auth/login', data={
                'username': 'testuser',
                'password': 'password123'
            })
            response = self.client.post('/favorites/add/1', follow_redirects=True)
            self.assertEqual(response.status_code, 200)
            self.assertIn(b"Added to Favorites", response.data)

    def test_recommendations(self):
        response = self.client.get('/recommendations', follow_redirects=True)
        self.assertEqual(response.status_code, 200)
        self.assertIn(b"Recommended Movies", response.data)

    def test_submit_review(self):
        with self.client:
            with app.app_context():
                User.create_user(username='testuser', password='password123')
            self.client.post('/auth/login', data={
                'username': 'testuser',
                'password': 'password123'
            })
            response = self.client.post('/movie/1/review', data={
                'rating': 8.5,
                'review_text': 'Great movie!'
            }, follow_redirects=True)
            self.assertEqual(response.status_code, 200)
            self.assertIn(b"Thank you for your review.", response.data)

    def test_page_not_found(self):
        response = self.client.get('/non-existent-page')
        self.assertEqual(response.status_code, 404)
        self.assertIn(b"Page Not Found", response.data)

    def test_personalized_recommendations(self):
        with self.client:
            with app.app_context():
                User.create_user(username='testuser', password='password123')
            self.client.post('/auth/login', data={
                'username': 'testuser',
                'password': 'password123'
            })
            response = self.client.get('/personalized', follow_redirects=True)
            self.assertEqual(response.status_code, 200)
            self.assertIn(b"Your Personalized Recommendations", response.data)


if __name__ == "__main__":
    unittest.main()
